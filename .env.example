# Telegram bot token (required)
BOT_TOKEN=your_bot_token_here

# Intelligent Golf club subdomain (optional, default: golf club)
# GOLF_CLUB=golf club

# Base directory for JSON data files: logins.json, monitogolfrs.json, etc. (optional, default: .)
# DATA_DIR=/var/lib/golf-bo

# Number of players to book per tee time: booker + (this us 1) others. Default: 3.
# BOOKING_NUM_SLOTS=3

# How often the /monitor job checks for new times (seconds). Default: 30. Min 15.
# MONITOR_INTERVAL_SECONDS=30

# If set to true or 1, auto-booking picks a random slot in your window (IGBookerBot-style).
# AUTO_BOOKING_RANDOM_SLOT=false

# When bookings open (used for reference; optional). Defaults: 18, 45, 5.
# BOOKING_HOUR=18
# BOOKING_MINUTE=45
# DAYS_AHEAD_TO_BOOK=5
#
# Optional: golfers for auto-booking. Copy autoBookingConfig.json.example to DATA_DIR/autoBookingConfig.json
# and add "with golfers" to /autobook or /addrecurringbooking to use those names in the confirmation message.
